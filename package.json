{
  "name": "prompt-inject-opencode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/src/index.js",
    "dev": "node --env-file-if-exists=.env --loader ts-node/esm src/index.ts",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "@tsconfig/node22": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
