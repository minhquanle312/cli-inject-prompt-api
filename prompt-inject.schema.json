{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unpkg.com/prompt-inject-opencode/prompt-inject.schema.json",
  "title": "Prompt Inject OpenCode Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "targets"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "targets": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "args_before_prompt"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "args_before_prompt": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "args_after_prompt": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
